# 复制本文件为 .env 并填入真实值，.env 不要提交到 git
DASHSCOPE_API_KEY=
BAILIAN_ASR_MODEL=paraformer-v2
BAILIAN_LLM_MODEL=qwen-plus
BAILIAN_TTS_MODEL=cosyvoice-v2
BAILIAN_TTS_VOICE=longxiaochun_v2
PUBLIC_AUDIO_BASE_URL=https://dashscope.oss-cn-beijing.aliyuncs.com/samples/audio/speech_recognition_test.wav

# ffmpeg / ffprobe：留空则用 PATH；找不到时可设置成完整路径
# 例如 Windows: FFMPEG_BINARY=C:\\ffmpeg\\bin\\ffmpeg.exe
FFMPEG_BINARY=
FFPROBE_BINARY=

VIDEO_ANALYSIS_PROVIDER=bailian
TTS_PROVIDER=bailian
EMBEDDING_PROVIDER=bailian
ASR_PROVIDER=bailian

SVC_PROVIDER=disabled
SINGING_PROVIDER=disabled

# 服务监听
HOST=0.0.0.0
PORT=8000
UVICORN_RELOAD=0

# === 鉴权 ===
# 留空 = 关闭鉴权（仅本地 dev）；公网部署务必设置！
# 多个 key 用英文逗号分隔。生成方式：python -c "import secrets;print(secrets.token_urlsafe(32))"
API_KEYS=

# === 限流（按客户端 IP 滑动窗口）===
# 设 0 关闭。默认每 IP 1 小时最多 20 次。
RATE_LIMIT_MAX=20
RATE_LIMIT_WINDOW_SEC=3600
